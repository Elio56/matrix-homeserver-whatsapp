# Matrix Homeserver Configuration
# Copy this file to .env and update values for your deployment

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_DB=synapse
POSTGRES_USER=synapse_tejas
POSTGRES_PASSWORD=change_me_to_secure_password

# ============================================
# Synapse Homeserver
# ============================================
SYNAPSE_SERVER_NAME=tejastesting.it.com
SYNAPSE_REPORT_STATS=yes
SYNAPSE_NO_TLS=true

# ============================================
# Docker Compose
# ============================================
# Project name for containers
COMPOSE_PROJECT_NAME=matrix-test

# ============================================
# Caddy Reverse Proxy
# ============================================
# Your domain (must match SYNAPSE_SERVER_NAME)
CADDY_DOMAIN=tejastesting.it.com

# ============================================
# WhatsApp Bridge
# ============================================
WHATSAPP_BRIDGE_ENABLED=true
